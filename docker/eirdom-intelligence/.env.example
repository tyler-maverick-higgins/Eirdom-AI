# ============================================================
# EIRDOM INTELLIGENCE — FOUNDATION STACK ENVIRONMENT VARIABLES
# ============================================================
#
# Copy this file to .env and fill in your values.
#
# NEVER commit .env
# Commit ONLY .env.example
#
# ============================================================

# ============================================================
# GENERAL
# ============================================================

TZ=America/Chicago
LOCAL_TIMEZONE=America/Chicago

PUID=1000
PGID=1000

# ============================================================
# HOST PATHS
# Windows workstation values below. On a Linux server, switch to
# Linux paths, e.g.:
#   EIRDOM_ROOT=/opt/eirdom
#   STACK_PATH=/opt/eirdom/docker/eirdom-intelligence
#   VAULT_PATH=/opt/eirdom/vault
# ============================================================

EIRDOM_ROOT=C:/Users/tyler/Projects/eirdom

STACK_PATH=C:/Users/tyler/Projects/eirdom/docker/eirdom-intelligence
VAULT_PATH=C:/Users/tyler/Projects/eirdom/vault


# Model store for an in-compose Ollama on a GPU server.
# Point at a fast, roomy disk. Uncomment with the `ollama` service.
# MODELS_PATH=D:/eirdom/models        # e.g. /opt/eirdom/models on Linux

# Reverse proxy (server only) — needed if you uncomment the Traefik
# labels on open-webui. Must match your Traefik ROOT_DOMAIN.
# ROOT_DOMAIN=eirdom.homes

# ============================================================
# OLLAMA
# ============================================================

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_FLASH_ATTENTION=1

# ============================================================
# QDRANT
# ============================================================

QDRANT_API_KEY=CHANGE_ME_TO_RANDOM_STRING
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ============================================================
# OPEN WEBUI
# ============================================================

WEBUI_PORT=3000
WEBUI_NAME=Eirdom Intelligence
WEBUI_SECRET_KEY=change-this-to-a-long-random-secret

VECTOR_DB=qdrant

RAG_EMBEDDING_ENGINE=ollama
RAG_EMBEDDING_MODEL=nomic-embed-text

# ============================================================
# MODELS
# ============================================================

PRIMARY_MODEL=qwen3:14b
REASONING_MODEL=qwen3:30b-a3b
EMBEDDING_MODEL=nomic-embed-text

# ============================================================
# MCPO / MCP GATEWAY
# ============================================================

MCPO_API_KEY=change-this-to-a-second-long-random-secret
MCPO_PORT=8000

# ============================================================
# MCP FILESYSTEM
# ============================================================

MCP_FILESYSTEM_ENABLED=true

MCP_FILESYSTEM_ROOT_1=C:/Users/tyler/Projects/eirdom/vault
MCP_FILESYSTEM_ROOT_2=C:/Users/tyler/Projects/eirdom/docs

MCP_FILESYSTEM_READONLY=true

# ============================================================
# MCP TIME
# ============================================================

MCP_TIME_ENABLED=true
MCP_TIMEZONE=America/Chicago

# ============================================================
# GIT
# ============================================================

GIT_USERNAME=Tyler Higgins
GIT_EMAIL=tylermaverickhiggins@gmail.com

# ============================================================
# DOCKER
# ============================================================

DOCKER_BIND_IP=127.0.0.1

QDRANT_PORT_BIND=6333
OPENWEBUI_PORT_BIND=3000
MCPO_PORT_BIND=8000

# ============================================================
# BACKUPS
# ============================================================

BACKUP_PATH=C:/Users/tyler/Projects/eirdom/backups

# ============================================================
# NOTES
#
# Open WebUI:
#   http://localhost:3000
#
# Qdrant:
#   http://localhost:6333/dashboard
#
# MCPO:
#   http://localhost:8000
#
# Ollama:
#   http://localhost:11434
#
# NEVER COMMIT:
#   .env
#
# ALWAYS COMMIT:
#   .env.example
#
# ============================================================
